# ── Verb: doctor ───────────────────────────────────────────────
cmd_doctor() {
  _parse_json_only_args "$@"

  local verdict="pass"
  local details=()
  local steps_json=""
  local missing_optional=()
  local missing_required=()

  _check_tool() {
    local name="$1" required="$2"
    local version_cmd="${3:-$name --version}"
    local ver=""
    local tool_verdict="pass"

    if command -v "$name" &>/dev/null; then
      ver=$(eval "$version_cmd" 2>/dev/null | head -1) || ver="installed"
      details+=("$name: $(_green "OK") ($ver)")
    else
      if [[ "$required" == "true" ]]; then
        tool_verdict="fail"
        missing_required+=("$name")
        details+=("$name: $(_red "MISSING") (required)")
      else
        tool_verdict="degraded"
        missing_optional+=("$name")
        details+=("$name: $(_yellow "MISSING") (optional)")
      fi
    fi

    if [[ -n "$steps_json" ]]; then steps_json+=","; fi
    steps_json+="{\"name\":\"$name\",\"verdict\":\"$tool_verdict\",\"exitCode\":$(if [[ "$tool_verdict" == "pass" ]]; then echo 0; elif [[ "$tool_verdict" == "fail" ]]; then echo 1; else echo 2; fi),\"durationMs\":0}"
  }

  _check_tool "node" "true" "node --version"
  _check_tool "npm" "true" "npm --version"
  _check_tool "git" "true" "git --version"
  _check_tool "just" "false" "just --version"
  _check_tool "tmux" "false" "tmux -V"
  _check_tool "curl" "false" "curl --version"

  # Check node_modules
  local nm_verdict="pass"
  if [[ -d "$HARNESS_DIR/node_modules" ]]; then
    details+=("node_modules: $(_green "OK") (installed)")
  else
    nm_verdict="degraded"
    missing_optional+=("node_modules")
    details+=("node_modules: $(_yellow "MISSING") (run ./harness install)")
  fi
  if [[ -n "$steps_json" ]]; then steps_json+=","; fi
  steps_json+="{\"name\":\"node_modules\",\"verdict\":\"$nm_verdict\",\"exitCode\":$(if [[ "$nm_verdict" == "pass" ]]; then echo 0; else echo 2; fi),\"durationMs\":0}"

  if [[ ${#missing_required[@]} -gt 0 ]]; then
    verdict="fail"
  elif [[ ${#missing_optional[@]} -gt 0 ]]; then
    verdict="degraded"
  fi

  local msg="Required: node, npm, git. Optional: just, tmux, curl, node_modules."
  if [[ ${#missing_required[@]} -gt 0 ]]; then
    msg="Missing required: ${missing_required[*]}"
  elif [[ ${#missing_optional[@]} -gt 0 ]]; then
    msg="Missing optional: ${missing_optional[*]}"
  else
    msg="All prerequisites satisfied"
  fi

  if $JSON_MODE; then
    _json_result_steps "doctor" "$verdict" "$steps_json" "" "$msg"
    _verdict_exit "$verdict"
    return $?
  fi

  echo ""
  _bold "Doctor — Prerequisites Check"
  echo ""
  for d in "${details[@]}"; do
    echo "  $d"
  done
  echo ""
  echo "Verdict: $(_verdict_label "$verdict") — $msg"
  _verdict_exit "$verdict"
}

# ── Generic command wrapper ────────────────────────────────────
_command_display() {
  local out="" part
  for part in "$@"; do
    if [[ -n "$out" ]]; then out+=" "; fi
    out+="$part"
  done
  printf '%s' "$out"
}

_run_wrapped() {
  local verb="$1" description="$2"
  shift 2
  local cmd=("$@")
  local command
  command="$(_command_display "${cmd[@]}")"
  local verdict="pass"
  local start_time end_time duration_ms exit_code=0

  if [[ ${#cmd[@]} -eq 0 ]]; then
    if $JSON_MODE; then
      _json_result "$verb" "unknown" "" "No backing command detected for '$verb'"
    else
      echo ""
      echo "Verb: $(_bold "$verb") — $description"
      echo "Command: $(_dim "none detected")"
      echo "Verdict: $(_verdict_label "unknown")"
    fi
    return 3
  fi

  start_time=$(date +%s%N 2>/dev/null || date +%s)

  if $JSON_MODE; then
    if (cd "$HARNESS_DIR" && "${cmd[@]}") >/dev/null 2>&1; then
      exit_code=0
      verdict="pass"
    else
      exit_code=$?
      verdict="fail"
    fi
  else
    echo ""
    echo "Verb: $(_bold "$verb") — $description"
    echo "Command: $(_cyan "$command")"
    echo ""
    if (cd "$HARNESS_DIR" && "${cmd[@]}"); then
      exit_code=0
      verdict="pass"
    else
      exit_code=$?
      verdict="fail"
    fi
  fi

  end_time=$(date +%s%N 2>/dev/null || date +%s)
  if [[ ${#start_time} -gt 10 ]]; then
    duration_ms=$(( (end_time - start_time) / 1000000 ))
  else
    duration_ms=$(( (end_time - start_time) * 1000 ))
  fi

  if $JSON_MODE; then
    local steps_json
    steps_json="{\"name\":\"$verb\",\"verdict\":\"$verdict\",\"exitCode\":$exit_code,\"durationMs\":$duration_ms}"
    _json_result_steps "$verb" "$verdict" "$steps_json" "" "$(if [[ "$verdict" == "pass" ]]; then echo "$verb completed successfully"; else echo "$verb failed with exit code $exit_code"; fi)"
  else
    echo ""
    echo "Verdict: $(_verdict_label "$verdict") $(if [[ "$verdict" == "fail" ]]; then echo "(exit code $exit_code)"; fi)"
  fi

  _verdict_exit "$verdict"
}


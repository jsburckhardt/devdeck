#!/usr/bin/env bash
# DevDeck Engineering Harness
# Repo-local CLI wrapping existing project commands.
# See .harness/README.md for full documentation.

set -euo pipefail

HARNESS_DIR="$(cd "$(dirname "$0")" && pwd)"
HARNESS_META_DIR="$HARNESS_DIR/.harness"
CONTRACT_PATH="$HARNESS_META_DIR/contract.yml"
FRICTION_PATH="$HARNESS_META_DIR/friction.jsonl"
EVIDENCE_DIR="$HARNESS_META_DIR/evidence"
RUN_DIR="$HARNESS_META_DIR/run"
VERSION="1.0.0"
NPM_BIN="${HARNESS_NPM_BIN:-npm}"
CURL_BIN="${HARNESS_CURL_BIN:-curl}"

# ── Color support ──────────────────────────────────────────────
USE_COLOR=true
if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
  USE_COLOR=false
fi

_green()  { $USE_COLOR && printf '\033[32m%s\033[0m' "$*" || printf '%s' "$*"; }
_red()    { $USE_COLOR && printf '\033[31m%s\033[0m' "$*" || printf '%s' "$*"; }
_yellow() { $USE_COLOR && printf '\033[33m%s\033[0m' "$*" || printf '%s' "$*"; }
_cyan()   { $USE_COLOR && printf '\033[36m%s\033[0m' "$*" || printf '%s' "$*"; }
_bold()   { $USE_COLOR && printf '\033[1m%s\033[0m' "$*" || printf '%s' "$*"; }
_dim()    { $USE_COLOR && printf '\033[2m%s\033[0m' "$*" || printf '%s' "$*"; }

# ── Verdict helpers ────────────────────────────────────────────
# pass=0, fail=1, degraded=2, unknown=3
_verdict_label() {
  case "$1" in
    pass)     _green "PASS" ;;
    fail)     _red "FAIL" ;;
    degraded) _yellow "DEGRADED" ;;
    unknown)  _dim "UNKNOWN" ;;
    *)        printf '%s' "$1" ;;
  esac
}

_verdict_exit() {
  case "$1" in
    pass)     return 0 ;;
    fail)     return 1 ;;
    degraded) return 2 ;;
    unknown)  return 3 ;;
    *)        return 3 ;;
  esac
}

# ── JSON helpers (no jq dependency) ────────────────────────────
_json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

_json_result() {
  local verb="$1" verdict="$2" command="${3:-}" message="${4:-}" evidence="${5:-}"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"verb":"%s","verdict":"%s","command":%s,"steps":[],"evidence":%s,"message":"%s","timestamp":"%s"}\n' \
    "$(_json_escape "$verb")" \
    "$(_json_escape "$verdict")" \
    "$(if [[ -n "$command" ]]; then printf '"%s"' "$(_json_escape "$command")"; else printf 'null'; fi)" \
    "$(if [[ -n "$evidence" ]]; then printf '"%s"' "$(_json_escape "$evidence")"; else printf 'null'; fi)" \
    "$(_json_escape "$message")" \
    "$ts"
}

_json_result_steps() {
  local verb="$1" verdict="$2" steps_json="$3" evidence="${4:-}" message="${5:-}"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"verb":"%s","verdict":"%s","command":null,"steps":[%s],"evidence":%s,"message":"%s","timestamp":"%s"}\n' \
    "$(_json_escape "$verb")" \
    "$(_json_escape "$verdict")" \
    "$steps_json" \
    "$(if [[ -n "$evidence" ]]; then printf '"%s"' "$(_json_escape "$evidence")"; else printf 'null'; fi)" \
    "$(_json_escape "$message")" \
    "$ts"
}

_json_result_meta() {
  local verb="$1" verdict="$2" command="${3:-}" message="${4:-}" evidence="${5:-}" metadata_json="${6:-null}"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"verb":"%s","verdict":"%s","command":%s,"steps":[],"evidence":%s,"message":"%s","timestamp":"%s","metadata":%s}\n' \
    "$(_json_escape "$verb")" \
    "$(_json_escape "$verdict")" \
    "$(if [[ -n "$command" ]]; then printf '"%s"' "$(_json_escape "$command")"; else printf 'null'; fi)" \
    "$(if [[ -n "$evidence" ]]; then printf '"%s"' "$(_json_escape "$evidence")"; else printf 'null'; fi)" \
    "$(_json_escape "$message")" \
    "$ts" \
    "$metadata_json"
}

_json_result_steps_meta() {
  local verb="$1" verdict="$2" steps_json="$3" evidence="${4:-}" message="${5:-}" metadata_json="${6:-null}" command="${7:-}"
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"verb":"%s","verdict":"%s","command":%s,"steps":[%s],"evidence":%s,"message":"%s","timestamp":"%s","metadata":%s}\n' \
    "$(_json_escape "$verb")" \
    "$(_json_escape "$verdict")" \
    "$(if [[ -n "$command" ]]; then printf '"%s"' "$(_json_escape "$command")"; else printf 'null'; fi)" \
    "$steps_json" \
    "$(if [[ -n "$evidence" ]]; then printf '"%s"' "$(_json_escape "$evidence")"; else printf 'null'; fi)" \
    "$(_json_escape "$message")" \
    "$ts" \
    "$metadata_json"
}

# ── Globals ────────────────────────────────────────────────────
JSON_MODE=false
STEP_TIMEOUT=300  # 5 minutes

# ── Ensure .harness dir exists ─────────────────────────────────
mkdir -p "$HARNESS_META_DIR" "$EVIDENCE_DIR"

_parse_json_only_args() {
  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--json" ]]; then
      JSON_MODE=true
    fi
    shift
  done
}


# ── Sanitized metadata helpers ─────────────────────────────────
_sanitize_label() {
  local s="$1"
  SANITIZED_TRUNCATED=false

  # Remove control characters before any JSON/evidence emission.
  s="$(printf '%s' "$s" | LC_ALL=C tr -d '[:cntrl:]')" || s=""

  # Redact credential-bearing URLs rather than trying to preserve host/path.
  if [[ "$s" =~ ^[A-Za-z][A-Za-z0-9+.-]*://[^/[:space:]]+@ ]]; then
    s="[redacted-url]"
  else
    # Drop query strings and fragments so tokens cannot appear in metadata.
    s="${s%%\?*}"
    s="${s%%#*}"
  fi

  # Avoid echoing sensitive environment variable names or values in metadata labels.
  if [[ "$s" == *DEVDECK_TOKEN* || "$s" == *DEVDECK_SECRET* || "$s" == *AUTH_TOKEN* || "$s" == *ACCESS_TOKEN* || "$s" == *PASSWORD* ]]; then
    s="[redacted-env]"
  fi

  # Repo-absolute paths become repo-relative. Other absolute paths are redacted.
  if [[ "$s" == "$HARNESS_DIR" ]]; then
    s="."
  elif [[ "$s" == "$HARNESS_DIR/"* ]]; then
    s="${s#$HARNESS_DIR/}"
  elif [[ "$s" == /* ]]; then
    s="[redacted-absolute-path]"
  fi

  if [[ ${#s} -gt 200 ]]; then
    s="${s:0:200}"
    SANITIZED_TRUNCATED=true
  fi

  SANITIZED_LABEL="$s"
}

_targets_metadata_json() {
  local count="$#"
  local targeted=false truncated=false
  local items="" raw
  if [[ "$count" -gt 0 ]]; then
    targeted=true
  fi
  for raw in "$@"; do
    _sanitize_label "$raw"
    if [[ "$SANITIZED_TRUNCATED" == "true" ]]; then
      truncated=true
    fi
    if [[ -n "$items" ]]; then items+=","; fi
    items+="\"$(_json_escape "$SANITIZED_LABEL")\""
  done
  printf '{"targeted":%s,"targets":[%s],"targetCount":%d,"truncated":%s}' "$targeted" "$items" "$count" "$truncated"
}

# ── Verb: test ─────────────────────────────────────────────────
cmd_test() {
  local passthrough=()
  local saw_delimiter=false

  while [[ $# -gt 0 ]]; do
    if $saw_delimiter; then
      passthrough+=("$1")
      shift
      continue
    fi

    case "$1" in
      --json)
        JSON_MODE=true
        ;;
      --)
        saw_delimiter=true
        ;;
      *)
        # Backward-compatible shorthand: non-harness args before the delimiter
        # are still forwarded, while harness --json remains delimiter-aware.
        passthrough+=("$1")
        ;;
    esac
    shift
  done

  local cmd=("$NPM_BIN" run test)
  local command_label="npm run test"
  if [[ ${#passthrough[@]} -gt 0 ]]; then
    cmd+=(-- "${passthrough[@]}")
    command_label="npm run test -- <${#passthrough[@]} target(s)>"
  fi

  local verdict="pass" exit_code=0
  local start_time end_time duration_ms
  local metadata_json
  metadata_json="$(_targets_metadata_json "${passthrough[@]}")"

  start_time=$(date +%s%N 2>/dev/null || date +%s)

  if $JSON_MODE; then
    if (cd "$HARNESS_DIR" && "${cmd[@]}") >/dev/null 2>&1; then
      exit_code=0
      verdict="pass"
    else
      exit_code=$?
      verdict="fail"
    fi
  else
    echo ""
    echo "Verb: $(_bold "test") — Run vitest test suite"
    echo "Command: $(_cyan "$command_label")"
    if [[ ${#passthrough[@]} -gt 0 ]]; then
      echo "Targets: ${#passthrough[@]} sanitized target(s)"
    fi
    echo ""
    if (cd "$HARNESS_DIR" && "${cmd[@]}"); then
      exit_code=0
      verdict="pass"
    else
      exit_code=$?
      verdict="fail"
    fi
  fi

  end_time=$(date +%s%N 2>/dev/null || date +%s)
  if [[ ${#start_time} -gt 10 ]]; then
    duration_ms=$(( (end_time - start_time) / 1000000 ))
  else
    duration_ms=$(( (end_time - start_time) * 1000 ))
  fi

  if $JSON_MODE; then
    local steps_json
    steps_json="{\"name\":\"test\",\"verdict\":\"$verdict\",\"exitCode\":$exit_code,\"durationMs\":$duration_ms,\"metadata\":$metadata_json}"
    _json_result_steps_meta "test" "$verdict" "$steps_json" "" "$(if [[ "$verdict" == "pass" ]]; then echo "test completed successfully"; else echo "test failed with exit code $exit_code"; fi)" "$metadata_json" "$command_label"
  else
    echo ""
    echo "Verdict: $(_verdict_label "$verdict") $(if [[ "$verdict" == "fail" ]]; then echo "(exit code $exit_code)"; fi)"
  fi

  _verdict_exit "$verdict"
}


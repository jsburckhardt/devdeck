  printf '%s/e2e-%s-%s-%s.lock' "$RUN_DIR" "$SMOKE_REPO_ID" "$role" "$port"
}

_e2e_write_owner_metadata() {
  local lock_dir="$1" role="$2" port="$3"
  local metadata_file="$lock_dir/owner.json"
  local tmp_file="$metadata_file.$$"
  local timestamp
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"version":1,"kind":"devdeck-harness-e2e","repoIdentity":"%s","role":"%s","port":%s,"parentPid":%s,"fixtureRunId":"%s","timestamp":"%s"}\n' \
    "$(_json_escape "$SMOKE_REPO_ID")" \
    "$(_json_escape "$role")" \
    "$port" \
    "$$" \
    "$(_json_escape "$E2E_RUN_ID")" \
    "$(_json_escape "$timestamp")" > "$tmp_file"
  mv -f -- "$tmp_file" "$metadata_file"
}

_e2e_release_lock() {
  local role="$1"
  local lock_dir=""
  if [[ "$role" == "web" ]]; then
    lock_dir="$E2E_WEB_LOCK_DIR"
    if [[ "$E2E_WEB_LOCK_OWNED" != "true" ]]; then return 0; fi
    E2E_WEB_LOCK_OWNED=false
    E2E_WEB_LOCK_DIR=""
  else
    lock_dir="$E2E_TERMINAL_LOCK_DIR"
    if [[ "$E2E_TERMINAL_LOCK_OWNED" != "true" ]]; then return 0; fi
    E2E_TERMINAL_LOCK_OWNED=false
    E2E_TERMINAL_LOCK_DIR=""
  fi
  case "$lock_dir" in
    "$RUN_DIR"/e2e-"$SMOKE_REPO_ID"-*.lock) rm -rf -- "$lock_dir" ;;
  esac
}

_e2e_cleanup() {
  _e2e_release_lock "web" || true
  _e2e_release_lock "terminal" || true
  if [[ -n "$E2E_SCRATCH_DIR" ]]; then
    case "$E2E_SCRATCH_DIR" in
      "$RUN_DIR"/e2e-*) rm -rf -- "$E2E_SCRATCH_DIR" ;;
    esac
  fi
  E2E_SCRATCH_DIR=""
}

_e2e_signal_exit() {
  _e2e_cleanup
  exit 1
}

_e2e_acquire_lock() {
  local role="$1" port="$2"
  local lock_dir
  _e2e_runtime_init || return 1
  lock_dir="$(_e2e_lock_dir_for "$role" "$port")"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    return 1
  fi
  if [[ "$role" == "web" ]]; then
    E2E_WEB_LOCK_DIR="$lock_dir"
    E2E_WEB_LOCK_OWNED=true
  else
    E2E_TERMINAL_LOCK_DIR="$lock_dir"
    E2E_TERMINAL_LOCK_OWNED=true
  fi
  _e2e_write_owner_metadata "$lock_dir" "$role" "$port"
}

_e2e_try_port() {
  local role="$1" port="$2"
  if _smoke_port_listening "$port"; then
    return 1
  fi
  if ! _e2e_acquire_lock "$role" "$port"; then
    return 1
  fi
  if _smoke_port_listening "$port"; then
    _e2e_release_lock "$role"
    return 1
  fi
  return 0
}

_e2e_json_array_from_args() {
  local items="" raw
  for raw in "$@"; do
    _sanitize_label "$raw"
    if [[ -n "$items" ]]; then items+=","; fi
    items+="\"$(_json_escape "$SANITIZED_LABEL")\""
  done
  printf '[%s]' "$items"
}

_e2e_playwright_projects_json() {
  local projects=()
  local expect_project_value=false
  local raw
  for raw in "$@"; do
    if $expect_project_value; then
      projects+=("$raw")
      expect_project_value=false
      continue
    fi
    case "$raw" in
      --project=*) projects+=("${raw#--project=}") ;;
      --project) expect_project_value=true ;;
    esac
  done
  if [[ ${#projects[@]} -eq 0 ]]; then
    projects=("chromium")
  fi
  _e2e_json_array_from_args "${projects[@]}"
}

_e2e_command_label() {
  local count="$1"
  if [[ "$count" -gt 0 ]]; then
    printf 'npm run e2e -- <%d target(s)>' "$count"
  else
    printf 'npm run e2e'
  fi
}

_e2e_script_available() {
  node -e '
const fs = require("node:fs");
const pkg = JSON.parse(fs.readFileSync("package.json", "utf8"));
process.exit(pkg.scripts && typeof pkg.scripts.e2e === "string" ? 0 : 1);
' >/dev/null 2>&1
}

_e2e_playwright_available() {
  [[ "${HARNESS_E2E_FORCE_NO_PLAYWRIGHT:-}" == "1" ]] && return 1
  [[ -x "$HARNESS_DIR/node_modules/.bin/playwright" || -d "$HARNESS_DIR/node_modules/@playwright/test" ]]
}

_e2e_setup_scratch() {
  mkdir -p "$RUN_DIR"
  local seed_dir="$HARNESS_DIR/e2e/fixtures"
  E2E_RUN_ID="e2e-$(date -u +%Y%m%dT%H%M%SZ)-$$"
  E2E_SCRATCH_DIR="$RUN_DIR/$E2E_RUN_ID"
  mkdir -p "$E2E_SCRATCH_DIR"
  if [[ -d "$seed_dir" ]]; then
    cp -R "$seed_dir/." "$E2E_SCRATCH_DIR/"
  fi
  E2E_PROJECTS_DIR="$E2E_SCRATCH_DIR/projects"
  E2E_DATA_DIR="$E2E_SCRATCH_DIR/.devdeck-data"
  mkdir -p "$E2E_PROJECTS_DIR" "$E2E_DATA_DIR"
}

_e2e_report_path() {
  printf '%s/test-results/playwright-results.json' "$HARNESS_DIR"
}

_e2e_test_counts_json() {
  local report_path
  report_path="$(_e2e_report_path)"
  node -e '
const fs = require("node:fs");
const reportPath = process.argv[1];
const counts = { passed: 0, failed: 0, skipped: 0, timedOut: 0, interrupted: 0 };
const bump = (status) => {
  if (status === "passed") counts.passed += 1;
  else if (status === "failed") counts.failed += 1;
  else if (status === "skipped") counts.skipped += 1;
  else if (status === "timedOut") counts.timedOut += 1;
  else if (status === "interrupted") counts.interrupted += 1;
};
const visitSuite = (suite) => {
  for (const spec of suite.specs || []) {
    for (const test of spec.tests || []) {
      const results = Array.isArray(test.results) ? test.results : [];
      const final = results.length > 0 ? results[results.length - 1].status : undefined;
      if (final) {
        bump(final);
      } else if (test.status === "skipped") {
        counts.skipped += 1;
      }
    }
  }
  for (const child of suite.suites || []) visitSuite(child);
};
try {
  const report = JSON.parse(fs.readFileSync(reportPath, "utf8"));
  for (const suite of report.suites || []) visitSuite(suite);
} catch {
  // Missing or malformed reports produce zero counts rather than leaking raw diagnostics.
}
process.stdout.write(JSON.stringify(counts));
' "$report_path" 2>/dev/null || printf '{"passed":0,"failed":0,"skipped":0,"timedOut":0,"interrupted":0}'
}

_e2e_metadata() {
  local reason="$1"
  local targets_base="${E2E_TARGETS_JSON%?}"
  local nested_targets="${targets_base#\{}"
  local reason_field=""
  if [[ "$E2E_VERDICT" != "pass" ]]; then
    reason_field=",\"reason\":\"$(_json_escape "$reason")\""
  fi
  local fields
  fields="\"playwrightProjects\":$E2E_PLAYWRIGHT_PROJECTS_JSON,\"testCounts\":$E2E_TEST_COUNTS_JSON,\"webHost\":\"127.0.0.1\",\"webPort\":${E2E_WEB_PORT:-null},\"terminalHost\":\"127.0.0.1\",\"terminalPort\":${E2E_TERMINAL_PORT:-null},\"fixtureRunId\":\"$(_json_escape "$E2E_RUN_ID")\",\"durationMs\":$E2E_DURATION_MS,\"artifactPaths\":[\"test-results\"]$reason_field"
  printf '%s,%s,"e2e":{%s,%s}}' \
    "$targets_base" \
    "$fields" \
    "$nested_targets" \
    "$fields"
}

_e2e_verify_metadata() {
  local reason_field=""
  if [[ "$E2E_VERDICT" != "pass" ]]; then
    reason_field=",\"reason\":\"$(_json_escape "$E2E_REASON")\""
  fi
  local targets_base="${E2E_TARGETS_JSON%?}"
  local nested_targets="${targets_base#\{}"
  local fields
  fields="\"playwrightProjects\":$E2E_PLAYWRIGHT_PROJECTS_JSON,\"testCounts\":$E2E_TEST_COUNTS_JSON,\"webPort\":${E2E_WEB_PORT:-null},\"terminalPort\":${E2E_TERMINAL_PORT:-null},\"fixtureRunId\":\"$(_json_escape "$E2E_RUN_ID")\",\"durationMs\":$E2E_DURATION_MS,\"artifactPaths\":[\"test-results\"]$reason_field"
  printf '%s,%s,"e2e":{%s,%s}}' \
    "$targets_base" \
    "$fields" \
    "$nested_targets" \
    "$fields"
}

_e2e_allocate_ports() {
  local fixed_web="${DEVDECK_E2E_WEB_PORT:-}"
  local fixed_terminal="${DEVDECK_E2E_TERMINAL_PORT:-}"
  local web_start terminal_start max_attempts attempt web_port terminal_port
  E2E_CANDIDATE_ATTEMPTS=0

  if [[ -n "$fixed_web" && ! "$fixed_web" =~ ^[0-9]+$ ]]; then
    E2E_REASON="invalid_web_port"
    return 1
  fi
  if [[ -n "$fixed_terminal" && ! "$fixed_terminal" =~ ^[0-9]+$ ]]; then
    E2E_REASON="invalid_terminal_port"
    return 1
  fi
  if [[ -n "$fixed_web" ]] && ! _valid_tcp_port "$fixed_web"; then
    E2E_REASON="invalid_web_port"
    return 1
  fi
  if [[ -n "$fixed_terminal" ]] && ! _valid_tcp_port "$fixed_terminal"; then
    E2E_REASON="invalid_terminal_port"
    return 1
  fi

  web_start="$(_bounded_int "${HARNESS_E2E_WEB_AUTO_START:-42000}" 42000 42999)"
  terminal_start="$(_bounded_int "${HARNESS_E2E_TERMINAL_AUTO_START:-43000}" 43000 43999)"
  if (( web_start < 42000 || web_start > 42999 )); then web_start=42000; fi
  if (( terminal_start < 43000 || terminal_start > 43999 )); then terminal_start=43000; fi
  max_attempts="$(_bounded_int "${HARNESS_E2E_AUTO_MAX_ATTEMPTS:-50}" 50 50)"

  for (( attempt=0; attempt<max_attempts; attempt++ )); do
    web_port="${fixed_web:-$((web_start + attempt))}"
    terminal_port="${fixed_terminal:-$((terminal_start + attempt))}"
    if [[ -z "$fixed_web" ]] && (( web_port > 42999 )); then break; fi
    if [[ -z "$fixed_terminal" ]] && (( terminal_port > 43999 )); then break; fi
    E2E_CANDIDATE_ATTEMPTS=$((E2E_CANDIDATE_ATTEMPTS + 1))

    if ! _e2e_try_port "web" "$web_port"; then
      _e2e_release_lock "web"
      _e2e_release_lock "terminal"
      if [[ -n "$fixed_web" ]]; then
        E2E_WEB_PORT="$web_port"
        E2E_TERMINAL_PORT="$terminal_port"
        E2E_REASON="fixed_web_port_in_use"
        return 2
      fi
      continue
    fi
    if ! _e2e_try_port "terminal" "$terminal_port"; then
      _e2e_release_lock "web"
      _e2e_release_lock "terminal"
      if [[ -n "$fixed_terminal" ]]; then
        E2E_WEB_PORT="$web_port"
        E2E_TERMINAL_PORT="$terminal_port"
        E2E_REASON="fixed_terminal_port_in_use"
        return 2
      fi
      continue
    fi

    E2E_WEB_PORT="$web_port"
    E2E_TERMINAL_PORT="$terminal_port"
    E2E_REASON="ports_reserved"
    return 0
  done

  E2E_WEB_PORT="${fixed_web:-$web_start}"
  E2E_TERMINAL_PORT="${fixed_terminal:-$terminal_start}"
  E2E_REASON="auto_port_exhausted"
  return 2
}

_e2e_run() {
  local command_label="$1"
  shift
  local passthrough=("$@")
  local start_time end_time
  start_time=$(date +%s%N 2>/dev/null || date +%s)
  E2E_VERDICT="unknown"
  E2E_EXIT_CODE=3
  E2E_DURATION_MS=0
  E2E_MESSAGE=""
  E2E_REASON="unknown"
  E2E_WEB_PORT=""
  E2E_TERMINAL_PORT=""
  E2E_RUN_ID=""
  E2E_SCRATCH_DIR=""
  E2E_PROJECTS_DIR=""
  E2E_DATA_DIR=""
  E2E_TARGETS_JSON="$(_targets_metadata_json "${passthrough[@]}")"
  E2E_PLAYWRIGHT_PROJECTS_JSON="$(_e2e_playwright_projects_json "${passthrough[@]}")"
  E2E_TEST_COUNTS_JSON='{"passed":0,"failed":0,"skipped":0,"timedOut":0,"interrupted":0}'

  trap _e2e_cleanup EXIT
  trap _e2e_signal_exit INT TERM

  if ! command -v "$NPM_BIN" >/dev/null 2>&1; then
    E2E_REASON="missing_npm"
    E2E_VERDICT="unknown"
    E2E_EXIT_CODE=3
  elif ! _e2e_script_available; then
    E2E_REASON="missing_e2e_script"
    E2E_VERDICT="unknown"
    E2E_EXIT_CODE=3
  elif ! _e2e_playwright_available; then
    E2E_REASON="missing_playwright"
    E2E_VERDICT="unknown"
    E2E_EXIT_CODE=3
  else
    _e2e_setup_scratch
    set +e
    _e2e_allocate_ports
    local allocate_rc=$?
    set -e
    if [[ "$allocate_rc" -eq 1 ]]; then
      E2E_VERDICT="fail"
      E2E_EXIT_CODE=1
    elif [[ "$allocate_rc" -eq 2 ]]; then
      E2E_VERDICT="degraded"
      E2E_EXIT_CODE=2
    else
      local cmd=("$NPM_BIN" run e2e)
      if [[ ${#passthrough[@]} -gt 0 ]]; then
        cmd+=(-- "${passthrough[@]}")
      fi
      local e2e_timeout
      e2e_timeout="$(_bounded_int "${HARNESS_E2E_TIMEOUT_SECONDS:-600}" 600 1800)"
      local run_env=(
        env
        DEVDECK_PROJECTS_DIR="$E2E_PROJECTS_DIR"
        DEVDECK_DATA_DIR="$E2E_DATA_DIR"
        DEVDECK_TOKEN="${DEVDECK_TOKEN:-devdeck-e2e-token}"
        DEVDECK_E2E_WEB_HOST="127.0.0.1"
        DEVDECK_E2E_WEB_PORT="$E2E_WEB_PORT"
        DEVDECK_E2E_TERMINAL_HOST="127.0.0.1"
        DEVDECK_E2E_TERMINAL_PORT="$E2E_TERMINAL_PORT"
        TERMINAL_HOST="127.0.0.1"
        TERMINAL_PORT="$E2E_TERMINAL_PORT"
        PORT="$E2E_WEB_PORT"
        PLAYWRIGHT_HTML_OPEN="never"
      )
      rm -f -- "$(_e2e_report_path)" 2>/dev/null || true
      set +e
      if $JSON_MODE; then
        (cd "$HARNESS_DIR" && timeout "$e2e_timeout" "${run_env[@]}" "${cmd[@]}") >/dev/null 2>&1
      else
        (cd "$HARNESS_DIR" && timeout "$e2e_timeout" "${run_env[@]}" "${cmd[@]}")
      fi
      local run_rc=$?
      set -e
      E2E_EXIT_CODE="$run_rc"
      if [[ "$run_rc" -eq 0 ]]; then
        E2E_VERDICT="pass"
        E2E_REASON="completed"
      elif [[ "$run_rc" -eq 124 ]]; then
        E2E_VERDICT="fail"
        E2E_REASON="timeout"
      else
        E2E_VERDICT="fail"
        E2E_REASON="playwright_failed"
      fi
      E2E_TEST_COUNTS_JSON="$(_e2e_test_counts_json)"
    fi
  fi

  end_time=$(date +%s%N 2>/dev/null || date +%s)
  if [[ ${#start_time} -gt 10 ]]; then
    E2E_DURATION_MS=$(( (end_time - start_time) / 1000000 ))
  else
    E2E_DURATION_MS=$(( (end_time - start_time) * 1000 ))
  fi

  case "$E2E_VERDICT" in
    pass) E2E_MESSAGE="E2E pass" ;;
    degraded) E2E_MESSAGE="E2E degraded: $E2E_REASON" ;;
    fail) E2E_MESSAGE="E2E failed: $E2E_REASON" ;;
    *) E2E_MESSAGE="E2E unknown: $E2E_REASON" ;;
  esac
  E2E_METADATA_JSON="$(_e2e_metadata "$E2E_REASON")"
  _e2e_cleanup
  trap - EXIT INT TERM
  set +e
  return "$E2E_EXIT_CODE"
}

# ── Verb: e2e ──────────────────────────────────────────────────
cmd_e2e() {
  local passthrough=()
  local saw_delimiter=false

  while [[ $# -gt 0 ]]; do
    if $saw_delimiter; then
      passthrough+=("$1")
      shift
      continue
    fi
    case "$1" in
      --json)
        JSON_MODE=true
        ;;
      --)
        saw_delimiter=true
        ;;
      --*)
        _e2e_fail_usage "Unknown harness e2e flag before --: $1"
        return $?
        ;;
      *)
        _e2e_fail_usage "Playwright arguments must follow --"
        return $?
        ;;
    esac
    shift
  done

  local command_label
  command_label="$(_e2e_command_label "${#passthrough[@]}")"
  set +e
  _e2e_run "$command_label" "${passthrough[@]}"
  local e2e_rc=$?
  set -e

  local steps_json
  steps_json="{\"name\":\"e2e\",\"verdict\":\"$E2E_VERDICT\",\"exitCode\":$E2E_EXIT_CODE,\"durationMs\":$E2E_DURATION_MS,\"metadata\":$E2E_METADATA_JSON}"
  if $JSON_MODE; then
    _json_result_steps_meta "e2e" "$E2E_VERDICT" "$steps_json" "" "$E2E_MESSAGE" "$E2E_METADATA_JSON" "$command_label"
  else
    echo ""
    echo "Verb: $(_bold "e2e") — Playwright browser E2E"
    echo "Command: $(_cyan "$command_label")"
    echo "Ports: web=${E2E_WEB_PORT:-unselected} terminal=${E2E_TERMINAL_PORT:-unselected}"
    echo "Verdict: $(_verdict_label "$E2E_VERDICT") — $E2E_MESSAGE"
  fi

  return "$e2e_rc"
}

# ── Verb: build ────────────────────────────────────────────────
cmd_build() {
  _parse_json_only_args "$@"
  _run_wrapped "build" "Build the Next.js application" "$NPM_BIN" run build
}

# ── Verb: boot ─────────────────────────────────────────────────
cmd_boot() {
  _parse_json_only_args "$@"

  if [[ ! -f "$HARNESS_DIR/src/server/start-dev.mts" ]]; then
    if $JSON_MODE; then
      _json_result "boot" "unknown" "npx tsx src/server/start-dev.mts" "Boot command path src/server/start-dev.mts does not exist"
    else
      echo ""
      echo "Verb: $(_bold "boot") — Start the development server"
      echo "Command: $(_cyan "npx tsx src/server/start-dev.mts")"
      echo "Verdict: $(_verdict_label "unknown") — boot command path does not exist"
    fi
    return 3
  fi
  _run_wrapped "boot" "Start the development server" npx tsx src/server/start-dev.mts
}

# ── Shared smoke implementation ────────────────────────────────
SMOKE_CHILD_PID=""
SMOKE_CLEANUP_RESULT="not_started"
SMOKE_VERDICT="unknown"
SMOKE_EXIT_CODE=3
SMOKE_METADATA_JSON="{}"
SMOKE_MESSAGE=""
SMOKE_DURATION_MS=0
SMOKE_PROCESS_GROUP_ID=""
SMOKE_LOCK_DIR=""
SMOKE_LOCK_OWNED=false
SMOKE_METADATA_FILE=""
SMOKE_REPO_REALPATH=""
SMOKE_REPO_ID=""
SMOKE_LOCK_BUSY_REASON=""
SMOKE_SELECTED_PORT=""
SMOKE_PORT_MODE="auto"
SMOKE_HTTP_STATUS=""

_smoke_usage() {
  cat <<'EOF'
Usage: ./harness smoke [--port auto|PORT] [--json]

Options:
  --port auto       Select an available loopback port from 41000-41999 (default)
  --port PORT       Use a fixed TCP port (1-65535)
  --json            Output machine-readable JSON
EOF
}

_smoke_fail_usage() {
  local reason="$1"
  local usage="Usage: ./harness smoke [--port auto|PORT] [--json]"
  if $JSON_MODE; then
    _json_result_meta "smoke" "fail" "" "$reason. $usage" "" '{"reason":"invalid_usage"}'
  else
    echo ""
    _smoke_usage
    echo ""
    echo "Verdict: $(_verdict_label "fail") — $reason"
  fi
  return 1
}

_valid_tcp_port() {
  local port="$1"
  [[ "$port" =~ ^[0-9]+$ ]] || return 1
  (( port >= 1 && port <= 65535 ))
}

_bounded_int() {
  local value="$1" default="$2" max="$3"
  if [[ "$value" =~ ^[0-9]+$ ]] && (( value > 0 )); then
    if (( value > max )); then
      printf '%s' "$max"
    else
      printf '%s' "$value"
    fi
  else
    printf '%s' "$default"
  fi
}

_smoke_port_listening() {
  local port="$1"
  node -e '
const net = require("node:net");
const port = Number(process.argv[1]);
const socket = net.createConnection({ host: "127.0.0.1", port });
let done = false;
const finish = (code) => {
  if (done) return;
  done = true;
  socket.destroy();
  process.exit(code);
};
socket.setTimeout(250);
socket.once("connect", () => finish(0));
socket.once("timeout", () => finish(1));
socket.once("error", () => finish(1));
' "$port" >/dev/null 2>&1
}

_smoke_child_running() {
  local pid="$1"
  local state=""
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  state="$(ps -p "$pid" -o stat= 2>/dev/null || true)"
  [[ -n "$state" && "$state" != *Z* ]]
}

_smoke_process_group_running() {
  local pgid="$1"
  local row_pgid state
  [[ "$pgid" =~ ^[0-9]+$ ]] || return 1
  while read -r row_pgid state; do
    row_pgid="${row_pgid//[[:space:]]/}"
    state="${state//[[:space:]]/}"
    if [[ "$row_pgid" == "$pgid" && -n "$state" && "$state" != *Z* ]]; then
      return 0
    fi
  done < <(ps -eo pgid=,stat= 2>/dev/null || true)
  return 1
}

_smoke_safe_process_group() {
  local pgid="$1"
  local current_pgid=""
  [[ "$pgid" =~ ^[0-9]+$ ]] || return 1
  (( pgid > 1 )) || return 1
  current_pgid="$(ps -o pgid= -p "$$" 2>/dev/null | tr -d '[:space:]' || true)"
  [[ -n "$current_pgid" && "$pgid" == "$current_pgid" ]] && return 1
  return 0
}

_smoke_runtime_init() {
  if [[ -z "$SMOKE_REPO_REALPATH" ]]; then
    if [[ -n "${HARNESS_SMOKE_REPO_REALPATH:-}" ]]; then
      SMOKE_REPO_REALPATH="$(printf '%s' "$HARNESS_SMOKE_REPO_REALPATH" | LC_ALL=C tr -d '[:cntrl:]')"
      [[ -n "$SMOKE_REPO_REALPATH" ]] || SMOKE_REPO_REALPATH="$(cd "$HARNESS_DIR" && pwd -P)"
    else
      SMOKE_REPO_REALPATH="$(cd "$HARNESS_DIR" && pwd -P)"
    fi
    SMOKE_REPO_ID="$(node -e 'const crypto = require("node:crypto"); process.stdout.write(crypto.createHash("sha256").update(process.argv[1]).digest("hex").slice(0, 16));' "$SMOKE_REPO_REALPATH")"
  fi
  mkdir -p "$RUN_DIR"
}

_smoke_command_summary() {
  local port="$1"
  printf 'npm run start -- --hostname 127.0.0.1 --port %s' "$port"
}

_smoke_lock_dir_for() {
  local port="$1"
  printf '%s/smoke-%s-%s.lock' "$RUN_DIR" "$SMOKE_REPO_ID" "$port"
}

_smoke_json_pid_or_null() {
  local pid="$1"
  if [[ "$pid" =~ ^[0-9]+$ ]]; then
    printf '%s' "$pid"
  else
    printf 'null'
  fi
}

_smoke_write_owner_metadata() {
  local port="$1" status="$2"
  local metadata_file="$SMOKE_METADATA_FILE"
  local tmp_file timestamp command_summary
  [[ -n "$metadata_file" ]] || return 1
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  command_summary="$(_smoke_command_summary "$port")"
  tmp_file="$metadata_file.$$"
  if ! printf '{"version":1,"kind":"devdeck-harness-smoke","repoIdentity":"%s","repoRealpath":"%s","port":%s,"parentPid":%s,"childPid":%s,"processGroupId":%s,"commandSummary":"%s","timestamp":"%s","status":"%s"}\n' \
    "$(_json_escape "$SMOKE_REPO_ID")" \
    "$(_json_escape "$SMOKE_REPO_REALPATH")" \
    "$port" \
    "$(_smoke_json_pid_or_null "$$")" \
    "$(_smoke_json_pid_or_null "$SMOKE_CHILD_PID")" \
    "$(_smoke_json_pid_or_null "$SMOKE_PROCESS_GROUP_ID")" \
    "$(_json_escape "$command_summary")" \
    "$(_json_escape "$timestamp")" \
    "$(_json_escape "$status")" > "$tmp_file"; then
    rm -f -- "$tmp_file"
    return 1
  fi
  mv -f -- "$tmp_file" "$metadata_file"
}

_smoke_safe_remove_lock() {
  local lock_dir="$1"
  case "$lock_dir" in
    "$RUN_DIR"/smoke-"$SMOKE_REPO_ID"-*.lock)
      rm -rf -- "$lock_dir"
      ;;
    *)
      return 1
      ;;
  esac
}

_smoke_lock_metadata_summary() {
  local metadata_file="$1" port="$2" expected_command="$3"
  node -e '
const fs = require("node:fs");
const [file, repoId, repoRealpath, port, expectedCommand] = process.argv.slice(1);
let metadata;
try {
  metadata = JSON.parse(fs.readFileSync(file, "utf8"));
} catch {
  process.exit(1);
}
const clean = (value) => value === undefined || value === null ? "" : String(value).replace(/[\r\n=]/g, "");
const pid = (value) => /^[0-9]+$/.test(clean(value)) ? clean(value) : "";
const repoMatch = clean(metadata.repoIdentity) === repoId && clean(metadata.repoRealpath) === repoRealpath ? "1" : "0";
const portMatch = Number(metadata.port) === Number(port) ? "1" : "0";
const commandMatch = clean(metadata.commandSummary) === expectedCommand ? "1" : "0";
process.stdout.write([
  `repoMatch=${repoMatch}`,
  `portMatch=${portMatch}`,
  `commandMatch=${commandMatch}`,
  `parentPid=${pid(metadata.parentPid)}`,
  `childPid=${pid(metadata.childPid)}`,
  `processGroupId=${pid(metadata.processGroupId)}`,
].join("\n"));
' "$metadata_file" "$SMOKE_REPO_ID" "$SMOKE_REPO_REALPATH" "$port" "$expected_command"
}

_smoke_terminate_stale_owned_process() {
  local child_pid="$1" process_group_id="$2"
  local waited=0

  if _smoke_safe_process_group "$process_group_id" && _smoke_process_group_running "$process_group_id"; then
    kill -TERM "-$process_group_id" 2>/dev/null || true
    while _smoke_process_group_running "$process_group_id"; do
      if (( waited >= 20 )); then
        kill -KILL "-$process_group_id" 2>/dev/null || true
        break
      fi
      sleep 0.1
      waited=$((waited + 1))
    done
    return 0
  fi

  if [[ "$child_pid" =~ ^[0-9]+$ ]] && _smoke_child_running "$child_pid"; then
    kill -TERM "$child_pid" 2>/dev/null || true
    while _smoke_child_running "$child_pid"; do
      if (( waited >= 20 )); then
        kill -KILL "$child_pid" 2>/dev/null || true
        break
      fi
      sleep 0.1
      waited=$((waited + 1))
    done
  fi
}

_smoke_reclaim_existing_lock() {
  local lock_dir="$1" port="$2"
  local metadata_file="$lock_dir/owner.json"
  local expected_command summary
  local repo_match=0 port_match=0 command_match=0 parent_pid="" child_pid="" process_group_id=""
  local key value

  [[ -d "$lock_dir" ]] || return 0

  if [[ ! -f "$metadata_file" ]]; then
    sleep 0.05
  fi
  if [[ ! -f "$metadata_file" ]]; then
    SMOKE_LOCK_BUSY_REASON="lock_without_metadata"
    return 1
  fi

  expected_command="$(_smoke_command_summary "$port")"
  if ! summary="$(_smoke_lock_metadata_summary "$metadata_file" "$port" "$expected_command" 2>/dev/null)"; then
    SMOKE_LOCK_BUSY_REASON="unreadable_lock_metadata"
    return 1
  fi

  while IFS='=' read -r key value; do
    case "$key" in
      repoMatch) repo_match="$value" ;;
      portMatch) port_match="$value" ;;
      commandMatch) command_match="$value" ;;
      parentPid) parent_pid="$value" ;;
      childPid) child_pid="$value" ;;
      processGroupId) process_group_id="$value" ;;
    esac
  done <<< "$summary"

  if [[ -n "$parent_pid" ]] && _smoke_child_running "$parent_pid"; then
    SMOKE_LOCK_BUSY_REASON="active_parent"
    return 1
  fi

  local child_alive=false group_alive=false
  if [[ -n "$child_pid" ]] && _smoke_child_running "$child_pid"; then
    child_alive=true
  fi
  if [[ -n "$process_group_id" ]] && _smoke_process_group_running "$process_group_id"; then
    group_alive=true
  fi

  if $child_alive || $group_alive; then
    if [[ "$repo_match" == "1" && "$port_match" == "1" && "$command_match" == "1" ]]; then
      _smoke_terminate_stale_owned_process "$child_pid" "$process_group_id"
      _smoke_safe_remove_lock "$lock_dir"
      return 0
    fi
    SMOKE_LOCK_BUSY_REASON="unproven_live_owner"
    return 1
  fi

  _smoke_safe_remove_lock "$lock_dir"
  return 0
}

_smoke_acquire_lock() {
  local port="$1"
  local lock_dir attempt
  _smoke_runtime_init || return 1
  lock_dir="$(_smoke_lock_dir_for "$port")"
  SMOKE_LOCK_BUSY_REASON=""

  for attempt in 1 2 3; do
    if mkdir "$lock_dir" 2>/dev/null; then
      SMOKE_LOCK_DIR="$lock_dir"
      SMOKE_METADATA_FILE="$lock_dir/owner.json"
      SMOKE_LOCK_OWNED=true
      SMOKE_PROCESS_GROUP_ID=""
      if _smoke_write_owner_metadata "$port" "reserved"; then
        return 0
      fi
      _smoke_safe_remove_lock "$lock_dir" || true
      SMOKE_LOCK_DIR=""
      SMOKE_METADATA_FILE=""
      SMOKE_LOCK_OWNED=false
      SMOKE_LOCK_BUSY_REASON="metadata_write_failed"
      return 1
    fi

    if _smoke_reclaim_existing_lock "$lock_dir" "$port"; then
      continue
    fi
    return 1
  done

  SMOKE_LOCK_BUSY_REASON="lock_acquire_failed"
  return 1
}

_smoke_release_lock() {
  if [[ "$SMOKE_LOCK_OWNED" == "true" && -n "$SMOKE_LOCK_DIR" ]]; then
    _smoke_safe_remove_lock "$SMOKE_LOCK_DIR" || true
  fi
  SMOKE_LOCK_DIR=""
  SMOKE_METADATA_FILE=""
  SMOKE_LOCK_OWNED=false
}

_smoke_cleanup() {
  local pid="${SMOKE_CHILD_PID:-}"
  if [[ -z "$pid" ]]; then
    _smoke_release_lock
    return 0
  fi

  if _smoke_child_running "$pid"; then
    SMOKE_CLEANUP_RESULT="terminated"
    _smoke_write_owner_metadata "${SMOKE_SELECTED_PORT:-0}" "cleaning" 2>/dev/null || true
    if _smoke_safe_process_group "${SMOKE_PROCESS_GROUP_ID:-}" && _smoke_process_group_running "$SMOKE_PROCESS_GROUP_ID"; then
      kill -TERM "-$SMOKE_PROCESS_GROUP_ID" 2>/dev/null || true
    else
      kill -TERM "$pid" 2>/dev/null || true
    fi
    local waited=0
    while _smoke_child_running "$pid"; do
      if (( waited >= 20 )); then
        if _smoke_safe_process_group "${SMOKE_PROCESS_GROUP_ID:-}" && _smoke_process_group_running "$SMOKE_PROCESS_GROUP_ID"; then
          kill -KILL "-$SMOKE_PROCESS_GROUP_ID" 2>/dev/null || true
        else
          kill -KILL "$pid" 2>/dev/null || true
        fi
        SMOKE_CLEANUP_RESULT="killed"
        break
      fi
      sleep 0.1
      waited=$((waited + 1))
    done
    wait "$pid" 2>/dev/null || true
  else
    SMOKE_CLEANUP_RESULT="already_exited"
    wait "$pid" 2>/dev/null || true
  fi
  SMOKE_CHILD_PID=""
  SMOKE_PROCESS_GROUP_ID=""
  _smoke_release_lock
}

_smoke_signal_exit() {
  _smoke_cleanup
  exit 1
}

_smoke_metadata() {
  local port_mode="$1" selected_port="$2" candidate_attempts="$3" readiness_attempts="$4" accepted_status="$5" duration_ms="$6" reason="$7"
  local selected_json="null"
  local accepted_json="null"
  if [[ -n "$selected_port" ]]; then selected_json="$selected_port"; fi
  if [[ -n "$accepted_status" ]]; then accepted_json="$accepted_status"; fi
  printf '{"portMode":"%s","selectedPort":%s,"bindHost":"127.0.0.1","probeHost":"127.0.0.1","autoRange":"41000-41999","maxCandidateAttempts":50,"candidateAttempts":%d,"readinessAttempts":%d,"acceptedStatus":%s,"durationMs":%d,"cleanup":"%s","reason":"%s"}' \
    "$(_json_escape "$port_mode")" \
    "$selected_json" \
    "$candidate_attempts" \
    "$readiness_attempts" \
    "$accepted_json" \
    "$duration_ms" \
    "$(_json_escape "$SMOKE_CLEANUP_RESULT")" \
    "$(_json_escape "$reason")"
}

_smoke_verify_metadata() {
  local selected_json="null"
  local http_status_json="null"
  if [[ -n "$SMOKE_SELECTED_PORT" ]]; then selected_json="$SMOKE_SELECTED_PORT"; fi
  if [[ -n "$SMOKE_HTTP_STATUS" ]]; then http_status_json="$SMOKE_HTTP_STATUS"; fi
  printf '{"portMode":"%s","selectedPort":%s,"httpStatus":%s,"timeoutSeconds":60,"pollIntervalMs":1000}' \
    "$(_json_escape "$SMOKE_PORT_MODE")" \
    "$selected_json" \
    "$http_status_json"
}

_smoke_capability_unknown() {
  local missing="$1" port_mode="$2" selected_port="$3" start_time="$4" candidate_attempts="${5:-0}" readiness_attempts="${6:-0}"
  local end_time duration_ms
  end_time=$(date +%s%N 2>/dev/null || date +%s)
  if [[ ${#start_time} -gt 10 ]]; then
    duration_ms=$(( (end_time - start_time) / 1000000 ))
  else
    duration_ms=$(( (end_time - start_time) * 1000 ))
  fi
  SMOKE_VERDICT="unknown"
  SMOKE_EXIT_CODE=3
  SMOKE_MESSAGE="Missing required smoke capability: $missing"
  SMOKE_DURATION_MS="$duration_ms"
  SMOKE_PORT_MODE="$port_mode"
  SMOKE_SELECTED_PORT="$selected_port"
  SMOKE_HTTP_STATUS=""
  SMOKE_METADATA_JSON="$(_smoke_metadata "$port_mode" "$selected_port" "$candidate_attempts" "$readiness_attempts" "" "$duration_ms" "missing_capability")"
  return 3
}

_smoke_run_candidate() {
  local port="$1" port_mode="$2"
  local readiness_limit="$3"
  local readiness_attempts=0
  local accepted_status=""
  local reason="readiness_timeout"
  local status=""

  SMOKE_CHILD_PID=""
  SMOKE_PROCESS_GROUP_ID=""
  SMOKE_SELECTED_PORT="$port"
  SMOKE_CLEANUP_RESULT="not_needed"
  _smoke_release_lock

  if [[ ! -f "$HARNESS_DIR/.next/BUILD_ID" && ! -d "$HARNESS_DIR/.next/server" ]]; then
    SMOKE_CANDIDATE_VERDICT="fail"
    SMOKE_CANDIDATE_EXIT=1
    SMOKE_CANDIDATE_REASON="missing_build"
    SMOKE_CANDIDATE_READINESS_ATTEMPTS=0
    SMOKE_CANDIDATE_ACCEPTED_STATUS=""
    return 1
  fi

  if ! _smoke_acquire_lock "$port"; then
    SMOKE_CANDIDATE_VERDICT="degraded"
    SMOKE_CANDIDATE_EXIT=2
    SMOKE_CANDIDATE_REASON="port_in_use"
    SMOKE_CANDIDATE_READINESS_ATTEMPTS=0
    SMOKE_CANDIDATE_ACCEPTED_STATUS=""
    return 2
  fi

  if _smoke_port_listening "$port"; then
    _smoke_release_lock
    SMOKE_CANDIDATE_VERDICT="degraded"
    SMOKE_CANDIDATE_EXIT=2
    SMOKE_CANDIDATE_REASON="port_in_use"
    SMOKE_CANDIDATE_READINESS_ATTEMPTS=0
    SMOKE_CANDIDATE_ACCEPTED_STATUS=""
    return 2
  fi

  (
    cd "$HARNESS_DIR"
    exec setsid "$NPM_BIN" run start -- --hostname 127.0.0.1 --port "$port"
  ) >/dev/null 2>&1 &
  SMOKE_CHILD_PID=$!
  SMOKE_PROCESS_GROUP_ID="$(ps -o pgid= -p "$SMOKE_CHILD_PID" 2>/dev/null | tr -d '[:space:]' || true)"
  SMOKE_CLEANUP_RESULT="pending"
  _smoke_write_owner_metadata "$port" "started" 2>/dev/null || true

  while (( readiness_attempts < readiness_limit )); do
    readiness_attempts=$((readiness_attempts + 1))

    status="$("$CURL_BIN" --silent --show-error --output /dev/null --write-out "%{http_code}" --max-time 2 "http://127.0.0.1:$port/" 2>/dev/null || printf '000')"
    status="${status: -3}"
    case "$status" in
      200|301|302|303|307|308)
        accepted_status="$status"
        reason="accepted_status"
        _smoke_cleanup
        SMOKE_CANDIDATE_VERDICT="pass"
        SMOKE_CANDIDATE_EXIT=0
        SMOKE_CANDIDATE_REASON="$reason"
        SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
        SMOKE_CANDIDATE_ACCEPTED_STATUS="$accepted_status"
        return 0
        ;;
      4??)
        reason="http_4xx"
        _smoke_cleanup
        SMOKE_CANDIDATE_VERDICT="fail"
        SMOKE_CANDIDATE_EXIT=1
        SMOKE_CANDIDATE_REASON="$reason"
        SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
        SMOKE_CANDIDATE_ACCEPTED_STATUS="$status"
        return 1
        ;;
      5??)
        reason="http_5xx"
        _smoke_cleanup
        SMOKE_CANDIDATE_VERDICT="fail"
        SMOKE_CANDIDATE_EXIT=1
        SMOKE_CANDIDATE_REASON="$reason"
        SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
        SMOKE_CANDIDATE_ACCEPTED_STATUS="$status"
        return 1
        ;;
    esac

    if ! _smoke_child_running "$SMOKE_CHILD_PID"; then
      wait "$SMOKE_CHILD_PID" 2>/dev/null || true
      SMOKE_CHILD_PID=""
      SMOKE_PROCESS_GROUP_ID=""
      SMOKE_CLEANUP_RESULT="already_exited"
      if _smoke_port_listening "$port"; then
        _smoke_release_lock
        SMOKE_CANDIDATE_VERDICT="degraded"
        SMOKE_CANDIDATE_EXIT=2
        SMOKE_CANDIDATE_REASON="port_in_use_race"
        SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
        SMOKE_CANDIDATE_ACCEPTED_STATUS=""
        return 2
      fi
      _smoke_release_lock
      SMOKE_CANDIDATE_VERDICT="fail"
      SMOKE_CANDIDATE_EXIT=1
      SMOKE_CANDIDATE_REASON="start_failed"
      SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
      SMOKE_CANDIDATE_ACCEPTED_STATUS=""
      return 1
    fi

    if (( readiness_attempts < readiness_limit )); then
      sleep 1
    fi
  done

  _smoke_cleanup
  SMOKE_CANDIDATE_VERDICT="fail"
  SMOKE_CANDIDATE_EXIT=1
  SMOKE_CANDIDATE_REASON="$reason"
  SMOKE_CANDIDATE_READINESS_ATTEMPTS="$readiness_attempts"
  SMOKE_CANDIDATE_ACCEPTED_STATUS=""
  return 1
}

_smoke_run() {
  local port_mode="$1" fixed_port="${2:-}"
  local start_time end_time duration_ms
  local candidate_attempts=0
  local readiness_attempts=0
  local accepted_status=""
  local selected_port=""
  local reason="unknown"

  start_time=$(date +%s%N 2>/dev/null || date +%s)
  SMOKE_VERDICT="unknown"
  SMOKE_EXIT_CODE=3
  SMOKE_MESSAGE=""
  SMOKE_METADATA_JSON="{}"
  SMOKE_DURATION_MS=0
  SMOKE_CHILD_PID=""
  SMOKE_PROCESS_GROUP_ID=""
  SMOKE_SELECTED_PORT=""
  SMOKE_PORT_MODE="$port_mode"
  SMOKE_HTTP_STATUS=""
  SMOKE_LOCK_DIR=""
  SMOKE_METADATA_FILE=""
  SMOKE_LOCK_OWNED=false
  SMOKE_CLEANUP_RESULT="not_started"

  trap _smoke_cleanup EXIT
  trap _smoke_signal_exit INT TERM

  if ! command -v "$NPM_BIN" >/dev/null 2>&1; then
    _smoke_capability_unknown "npm" "$port_mode" "$selected_port" "$start_time"
    trap - EXIT INT TERM
    return 3
  fi
  if ! command -v "$CURL_BIN" >/dev/null 2>&1; then
    _smoke_capability_unknown "curl" "$port_mode" "$selected_port" "$start_time"
    trap - EXIT INT TERM
    return 3
  fi
  if ! command -v node >/dev/null 2>&1; then
    _smoke_capability_unknown "node" "$port_mode" "$selected_port" "$start_time"
    trap - EXIT INT TERM
    return 3
  fi
  if ! command -v setsid >/dev/null 2>&1; then
    _smoke_capability_unknown "setsid" "$port_mode" "$selected_port" "$start_time"
    trap - EXIT INT TERM
    return 3
  fi

  local readiness_limit
  readiness_limit="$(_bounded_int "${HARNESS_SMOKE_READINESS_ATTEMPTS:-60}" 60 60)"

  if [[ "$port_mode" == "fixed" ]]; then
    selected_port="$fixed_port"
    candidate_attempts=1
    local candidate_rc=0
    if _smoke_run_candidate "$selected_port" "$port_mode" "$readiness_limit"; then
      candidate_rc=0
    else
      candidate_rc=$?
    fi
    readiness_attempts="$SMOKE_CANDIDATE_READINESS_ATTEMPTS"
    accepted_status="$SMOKE_CANDIDATE_ACCEPTED_STATUS"
    reason="$SMOKE_CANDIDATE_REASON"
    SMOKE_VERDICT="$SMOKE_CANDIDATE_VERDICT"
    SMOKE_EXIT_CODE="$SMOKE_CANDIDATE_EXIT"
    if [[ "$reason" == "port_in_use" || "$reason" == "port_in_use_race" ]]; then
      SMOKE_VERDICT="degraded"
      SMOKE_EXIT_CODE=2
      reason="fixed_port_in_use"
    fi
    candidate_rc="$SMOKE_EXIT_CODE"
  else
    local auto_start max_attempts port
    auto_start="$(_bounded_int "${HARNESS_SMOKE_AUTO_START:-41000}" 41000 41999)"
    if (( auto_start < 41000 || auto_start > 41999 )); then auto_start=41000; fi
    max_attempts="$(_bounded_int "${HARNESS_SMOKE_AUTO_MAX_ATTEMPTS:-50}" 50 50)"

    port="$auto_start"
    while (( candidate_attempts < max_attempts && port <= 41999 )); do
      selected_port="$port"
      candidate_attempts=$((candidate_attempts + 1))
      local candidate_rc=0
      if _smoke_run_candidate "$selected_port" "$port_mode" "$readiness_limit"; then
        candidate_rc=0
      else
        candidate_rc=$?
      fi
      readiness_attempts=$((readiness_attempts + SMOKE_CANDIDATE_READINESS_ATTEMPTS))
      accepted_status="$SMOKE_CANDIDATE_ACCEPTED_STATUS"
      reason="$SMOKE_CANDIDATE_REASON"
      if [[ "$SMOKE_CANDIDATE_VERDICT" == "pass" ]]; then
        SMOKE_VERDICT="pass"
        SMOKE_EXIT_CODE=0
        break
      elif [[ "$SMOKE_CANDIDATE_VERDICT" == "degraded" && ( "$reason" == "port_in_use" || "$reason" == "port_in_use_race" ) ]]; then
        port=$((port + 1))
        continue
      else
        SMOKE_VERDICT="$SMOKE_CANDIDATE_VERDICT"
        SMOKE_EXIT_CODE="$SMOKE_CANDIDATE_EXIT"
        break
      fi
    done

    if [[ "$SMOKE_VERDICT" == "unknown" ]]; then
      SMOKE_VERDICT="degraded"
      SMOKE_EXIT_CODE=2
      reason="auto_port_exhausted"
    elif [[ "$SMOKE_VERDICT" != "pass" && "$reason" == "port_in_use" ]]; then
      SMOKE_VERDICT="degraded"
      SMOKE_EXIT_CODE=2
      reason="auto_port_exhausted"
    fi
  fi

  end_time=$(date +%s%N 2>/dev/null || date +%s)
  if [[ ${#start_time} -gt 10 ]]; then
    duration_ms=$(( (end_time - start_time) / 1000000 ))
  else
    duration_ms=$(( (end_time - start_time) * 1000 ))
  fi
  SMOKE_DURATION_MS="$duration_ms"

  case "$SMOKE_VERDICT" in
    pass) SMOKE_MESSAGE="Smoke passed on port $selected_port" ;;
    degraded) SMOKE_MESSAGE="Smoke degraded: $reason" ;;
    fail) SMOKE_MESSAGE="Smoke failed: $reason" ;;
    *) SMOKE_MESSAGE="Smoke unknown: $reason" ;;
  esac

  SMOKE_PORT_MODE="$port_mode"
  SMOKE_SELECTED_PORT="$selected_port"
  SMOKE_HTTP_STATUS="$accepted_status"
  SMOKE_METADATA_JSON="$(_smoke_metadata "$port_mode" "$selected_port" "$candidate_attempts" "$readiness_attempts" "$accepted_status" "$duration_ms" "$reason")"

  _smoke_cleanup
  trap - EXIT INT TERM
  return "$SMOKE_EXIT_CODE"
}

# ── Verb: smoke ────────────────────────────────────────────────
cmd_smoke() {
  local port_mode="auto"
  local port_value=""
  local saw_port=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        JSON_MODE=true
        ;;
      --port)
        if $saw_port; then
          _smoke_fail_usage "Duplicate --port value"
          return $?
        fi
        saw_port=true
        shift
        if [[ $# -eq 0 || -z "${1:-}" || "${1:-}" == --* ]]; then
          _smoke_fail_usage "Missing --port value"
          return $?
        fi
        port_value="$1"
        ;;
      --port=*)
        if $saw_port; then
          _smoke_fail_usage "Duplicate --port value"
          return $?
        fi
        saw_port=true
        port_value="${1#--port=}"
        if [[ -z "$port_value" ]]; then
          _smoke_fail_usage "Missing --port value"
          return $?
        fi
        ;;
      --*)
        _smoke_fail_usage "Unknown smoke flag: $1"
        return $?
        ;;
      *)
        _smoke_fail_usage "Unknown smoke argument: $1"
        return $?
        ;;
    esac
    shift
  done

  if [[ -z "$port_value" || "$port_value" == "auto" ]]; then
    port_mode="auto"
    port_value=""
  elif _valid_tcp_port "$port_value"; then
    port_mode="fixed"
  else
    _smoke_fail_usage "Invalid --port value: $port_value"
    return $?
  fi

  set +e
  _smoke_run "$port_mode" "$port_value"
  local smoke_rc=$?
  set -e

  local command_label="npm run start -- --hostname 127.0.0.1 --port <selectedPort>"
  local steps_json="{\"name\":\"smoke\",\"verdict\":\"$SMOKE_VERDICT\",\"exitCode\":$SMOKE_EXIT_CODE,\"durationMs\":$SMOKE_DURATION_MS,\"metadata\":$SMOKE_METADATA_JSON}"
  if $JSON_MODE; then
    _json_result_steps_meta "smoke" "$SMOKE_VERDICT" "$steps_json" "" "$SMOKE_MESSAGE" "$SMOKE_METADATA_JSON" "$command_label"
  else
    echo ""
    echo "Verb: $(_bold "smoke") — Built-app loopback smoke"
    echo "Command: $(_cyan "$command_label")"
    echo "Mode: $port_mode"
    echo "Verdict: $(_verdict_label "$SMOKE_VERDICT") — $SMOKE_MESSAGE"
  fi

  return "$smoke_rc"
}

# ── Verb: verify ───────────────────────────────────────────────
cmd_verify() {
  _parse_json_only_args "$@"

  local overall_verdict="pass"
  local steps_json=""
  local step_results=()
  local evidence_name="verify-$(date -u +%Y%m%dT%H%M%SZ)-$$.json"
  local evidence_file="$EVIDENCE_DIR/$evidence_name"
  local evidence_ref=".harness/evidence/$evidence_name"

  _aggregate_verdict() {
    local step_verdict="$1"
    local current_rank=0 step_rank=0
    case "$overall_verdict" in
      fail) current_rank=3 ;;
      degraded) current_rank=2 ;;
      unknown) current_rank=1 ;;
      *) current_rank=0 ;;
    esac
    case "$step_verdict" in
      fail) step_rank=3 ;;
      degraded) step_rank=2 ;;
      unknown) step_rank=1 ;;
      *) step_rank=0 ;;
    esac
    if (( step_rank > current_rank )); then
      overall_verdict="$step_verdict"
    fi
  }

  _run_verify_step() {
    local name="$1" description="$2"
    shift 2
    local cmd=("$@")
    local step_verdict="pass" exit_code=0
    local start_time end_time duration_ms

    start_time=$(date +%s%N 2>/dev/null || date +%s)

    if ! $JSON_MODE; then
      printf "  %-15s " "$name"
    fi

    if (cd "$HARNESS_DIR" && timeout "$STEP_TIMEOUT" "${cmd[@]}") >/dev/null 2>&1; then
      exit_code=0
      step_verdict="pass"
    else
      exit_code=$?
      if [[ $exit_code -eq 124 ]]; then
        step_verdict="fail"
        if ! $JSON_MODE; then
          printf "%s (timed out after %ds)\n" "$(_verdict_label "fail")" "$STEP_TIMEOUT"
        fi
      else
        step_verdict="fail"
      fi
    fi

    end_time=$(date +%s%N 2>/dev/null || date +%s)
    if [[ ${#start_time} -gt 10 ]]; then
      duration_ms=$(( (end_time - start_time) / 1000000 ))
    else
      duration_ms=$(( (end_time - start_time) * 1000 ))
    fi

    if ! $JSON_MODE && [[ $exit_code -ne 124 ]]; then
      printf "%s (%dms)\n" "$(_verdict_label "$step_verdict")" "$duration_ms"
    fi

    if [[ -n "$steps_json" ]]; then steps_json+=","; fi
    steps_json+="{\"name\":\"$(_json_escape "$name")\",\"verdict\":\"$step_verdict\",\"exitCode\":$exit_code,\"durationMs\":$duration_ms}"

    step_results+=("{\"name\":\"$(_json_escape "$name")\",\"verdict\":\"$step_verdict\",\"exitCode\":$exit_code,\"durationMs\":$duration_ms,\"description\":\"$(_json_escape "$description")\"}")

    _aggregate_verdict "$step_verdict"
  }

  if ! $JSON_MODE; then
    echo ""
    _bold "Verify — Full Verification Sequence"
    echo ""
  fi

  _run_verify_step "lint" "Run ESLint on the codebase" "$NPM_BIN" run lint
  _run_verify_step "format_check" "Check code formatting with Prettier" "$NPM_BIN" run format:check
  _run_verify_step "build" "Build the Next.js application" "$NPM_BIN" run build
  _run_verify_step "test" "Run vitest test suite" "$NPM_BIN" run test

  if ! $JSON_MODE; then
    printf "  %-15s " "smoke"
  fi

  set +e
  _smoke_run "auto" ""
  set -e
  local verify_smoke_metadata
  verify_smoke_metadata="$(_smoke_verify_metadata)"

  if ! $JSON_MODE; then
    printf "%s (%dms)\n" "$(_verdict_label "$SMOKE_VERDICT")" "$SMOKE_DURATION_MS"
  fi

  if [[ -n "$steps_json" ]]; then steps_json+=","; fi
  steps_json+="{\"name\":\"smoke\",\"verdict\":\"$SMOKE_VERDICT\",\"exitCode\":$SMOKE_EXIT_CODE,\"durationMs\":$SMOKE_DURATION_MS,\"metadata\":$verify_smoke_metadata}"
  step_results+=("{\"name\":\"smoke\",\"verdict\":\"$SMOKE_VERDICT\",\"exitCode\":$SMOKE_EXIT_CODE,\"durationMs\":$SMOKE_DURATION_MS,\"description\":\"Start the built app and verify it responds to HTTP\",\"metadata\":$verify_smoke_metadata}")
  _aggregate_verdict "$SMOKE_VERDICT"

  if ! $JSON_MODE; then
    printf "  %-15s " "e2e"
  fi

  set +e
  local saved_json_mode="$JSON_MODE"
  JSON_MODE=true
  _e2e_run "npm run e2e"
  local e2e_rc=$?
  JSON_MODE="$saved_json_mode"
  set -e
  : "$e2e_rc"
  local verify_e2e_metadata
  verify_e2e_metadata="$(_e2e_verify_metadata)"

  if ! $JSON_MODE; then
    printf "%s (%dms)\n" "$(_verdict_label "$E2E_VERDICT")" "$E2E_DURATION_MS"
  fi

  if [[ -n "$steps_json" ]]; then steps_json+=","; fi
  steps_json+="{\"name\":\"e2e\",\"verdict\":\"$E2E_VERDICT\",\"exitCode\":$E2E_EXIT_CODE,\"durationMs\":$E2E_DURATION_MS,\"metadata\":$verify_e2e_metadata}"
  step_results+=("{\"name\":\"e2e\",\"verdict\":\"$E2E_VERDICT\",\"exitCode\":$E2E_EXIT_CODE,\"durationMs\":$E2E_DURATION_MS,\"description\":\"Run Playwright browser E2E through isolated harness runtime\",\"metadata\":$verify_e2e_metadata}")
  _aggregate_verdict "$E2E_VERDICT"

  # Write evidence
  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf '{"harness_version":"%s","verb":"verify","verdict":"%s","timestamp":"%s","steps":[%s]}\n' \
    "$VERSION" "$overall_verdict" "$ts" \
    "$(IFS=,; echo "${step_results[*]}")" \
    > "$evidence_file"

  if ! $JSON_MODE; then
    echo ""
    echo "Evidence: $(_dim "$evidence_ref")"
    echo "Verdict:  $(_verdict_label "$overall_verdict")"
  fi

  if $JSON_MODE; then
    _json_result_steps "verify" "$overall_verdict" "$steps_json" "$evidence_ref" "Verification $overall_verdict"
  fi

  _verdict_exit "$overall_verdict"
}

# ── Verb: status ───────────────────────────────────────────────
cmd_status() {
  _parse_json_only_args "$@"

  local verdict="pass"
  local msg=""

  # Check contract
  local contract_ok=true
  if [[ ! -f "$CONTRACT_PATH" ]]; then
    contract_ok=false
    verdict="degraded"
  elif [[ ! -s "$CONTRACT_PATH" ]]; then
    contract_ok=false
    verdict="degraded"
  fi

  # Find latest evidence
  local latest_evidence=""
  local latest_verdict=""
  if [[ -d "$EVIDENCE_DIR" ]]; then
    latest_evidence=$(ls -t "$EVIDENCE_DIR"/verify-*.json 2>/dev/null | head -1 || true)
    if [[ -n "$latest_evidence" ]]; then
      latest_verdict=$(grep -o '"verdict":"[^"]*"' "$latest_evidence" 2>/dev/null | head -1 | cut -d'"' -f4 || true)
    fi
  fi

  # Count friction entries
  local friction_count=0
  if [[ -f "$FRICTION_PATH" ]]; then
    friction_count=$(wc -l < "$FRICTION_PATH" | tr -d ' ')
  fi

  if [[ "$contract_ok" == "false" ]]; then
    msg="Contract file missing or empty"
  elif [[ -z "$latest_evidence" ]]; then
    msg="No verification evidence found. Run ./harness verify."
  else
    msg="Last verify: $latest_verdict ($(basename "$latest_evidence"))"
  fi

  if $JSON_MODE; then
    local ts
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    printf '{"verb":"status","verdict":"%s","command":null,"steps":[],"evidence":%s,"message":"%s","timestamp":"%s","friction_count":%d,"contract_valid":%s}\n' \
      "$verdict" \
      "$(if [[ -n "$latest_evidence" ]]; then printf '"%s"' "$(_json_escape ".harness/evidence/$(basename "$latest_evidence")")"; else printf 'null'; fi)" \
      "$(_json_escape "$msg")" \
      "$ts" \
      "$friction_count" \
      "$contract_ok"
    _verdict_exit "$verdict"
    return $?
  fi

  echo ""
  _bold "Status — Harness Configuration"
  echo ""
  echo "  Version:         $VERSION"
  echo "  Contract:        $(if $contract_ok; then _green "valid"; else _yellow "missing/empty"; fi)"
  echo "  Friction entries: $friction_count"
  echo "  Evidence dir:    $EVIDENCE_DIR"
  if [[ -n "$latest_evidence" ]]; then
    echo "  Latest evidence: $(basename "$latest_evidence") ($latest_verdict)"
  else
    echo "  Latest evidence: $(_dim "none — run ./harness verify")"
  fi
  echo ""
  echo "Verdict: $(_verdict_label "$verdict") — $msg"
  _verdict_exit "$verdict"
}

# ── Verb: clean ────────────────────────────────────────────────
cmd_clean() {
  local clean_args=()
  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--json" ]]; then
      JSON_MODE=true
    else
      clean_args+=("$1")
    fi
    shift
  done
  set -- "${clean_args[@]+"${clean_args[@]}"}"

  # Safety: refuse to run if cwd is not the repo root
  if [[ ! -f "$(pwd)/harness" ]]; then
    if $JSON_MODE; then
      _json_result "clean" "fail" "" "Refusing to clean: ./harness not found in current working directory"
    else
      echo ""
      echo "Verdict: $(_verdict_label "fail") — Refusing to clean: not in repo root"
    fi
    return 1
  fi

  local targets=()
  [[ -d "$HARNESS_DIR/.next" ]] && targets+=(".next")
  [[ -d "$HARNESS_DIR/node_modules" ]] && targets+=("node_modules")

  if [[ ${#targets[@]} -eq 0 ]]; then
    if $JSON_MODE; then
      _json_result "clean" "pass" "rm -rf .next node_modules" "Nothing to clean"
    else
      echo ""
      echo "Verb: $(_bold "clean") — Remove build artifacts"
      echo "Verdict: $(_verdict_label "pass") — Nothing to clean"
    fi
    return 0
  fi

  local yes_flag=false
  for arg in "$@"; do
    [[ "$arg" == "--yes" || "$arg" == "-y" ]] && yes_flag=true
  done

  if ! $yes_flag && [[ -t 0 ]]; then
    echo ""
    echo "The following will be deleted:"
    for t in "${targets[@]}"; do
      echo "  $(_red "rm -rf") $t"
    done
    printf "\nProceed? [y/N] "
    read -r confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      if $JSON_MODE; then
        _json_result "clean" "fail" "rm -rf .next node_modules" "Clean cancelled by user"
      else
        echo "Verdict: $(_verdict_label "fail") — Cancelled"
      fi
      return 1
    fi
  elif ! $yes_flag && [[ ! -t 0 ]]; then
    if $JSON_MODE; then
      _json_result "clean" "fail" "rm -rf .next node_modules" "Non-interactive context requires --yes flag"
    else
      echo ""
      echo "Verdict: $(_verdict_label "fail") — Non-interactive context requires --yes flag"
    fi
    return 1
  fi

  cd "$HARNESS_DIR"
  if rm -rf .next node_modules 2>/dev/null; then
    if $JSON_MODE; then
      _json_result "clean" "pass" "rm -rf .next node_modules" "Cleaned: ${targets[*]}"
    else
      echo ""
      echo "Verb: $(_bold "clean") — Remove build artifacts"
      echo "Removed: ${targets[*]}"
      echo "Verdict: $(_verdict_label "pass")"
    fi
    return 0
  else
    if $JSON_MODE; then
      _json_result "clean" "fail" "rm -rf .next node_modules" "Clean failed"
    else
      echo "Verdict: $(_verdict_label "fail") — Clean failed"
    fi
    return 1
  fi
}

# ── Verb: friction ─────────────────────────────────────────────
cmd_friction() {
  local subcmd="${1:-}"
  shift 1 2>/dev/null || true

  case "$subcmd" in
    add)
      local verb_name="unknown"
      local message=""
      # If first arg looks like a verb name (no spaces, short), treat it as the verb
      if [[ $# -ge 2 ]] && [[ "$1" != *" "* ]] && [[ ${#1} -le 30 ]]; then
        verb_name="$1"
        shift
      fi
      message="$*"
      if [[ -z "$message" ]]; then
        if $JSON_MODE; then
          _json_result "friction add" "fail" "" "Usage: ./harness friction add \"<message>\""
        else
          echo ""
          echo "Usage: ./harness friction add \"<message>\""
          echo "Verdict: $(_verdict_label "fail") — Empty friction message"
        fi
        return 1
      fi
      local ts
      ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
      printf '{"timestamp":"%s","verb":"%s","inference":"%s","question":"What did the agent have to infer that the harness should have proved?"}\n' \
        "$ts" "$(_json_escape "$verb_name")" "$(_json_escape "$message")" >> "$FRICTION_PATH"
      if $JSON_MODE; then
        _json_result "friction add" "pass" "" "Friction recorded"
      else
        echo ""
        echo "Friction recorded: $message"
        echo "Verdict: $(_verdict_label "pass")"
      fi
      return 0
      ;;
    list)
      if [[ ! -f "$FRICTION_PATH" ]] || [[ ! -s "$FRICTION_PATH" ]]; then
        if $JSON_MODE; then
          local ts
          ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
          printf '{"verb":"friction list","verdict":"pass","command":null,"steps":[],"evidence":null,"message":"No friction entries recorded","timestamp":"%s","entries":[]}\n' "$ts"
        else
          echo ""
          echo "No friction entries recorded."
          echo "Verdict: $(_verdict_label "pass")"
        fi
        return 0
      fi

      if $JSON_MODE; then
        local entries=""
        while IFS= read -r line; do
          if [[ -n "$entries" ]]; then entries+=","; fi
          entries+="$line"
        done < "$FRICTION_PATH"
        local ts
        ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        printf '{"verb":"friction list","verdict":"pass","command":null,"steps":[],"evidence":null,"message":"%d friction entries","timestamp":"%s","entries":[%s]}\n' \
          "$(wc -l < "$FRICTION_PATH" | tr -d ' ')" "$ts" "$entries"
      else
        echo ""
        _bold "Friction Log"
        echo ""
        local i=1
        while IFS= read -r line; do
          local inf ts_val
          inf=$(echo "$line" | grep -o '"inference":"[^"]*"' | cut -d'"' -f4)
          ts_val=$(echo "$line" | grep -o '"timestamp":"[^"]*"' | cut -d'"' -f4)
          printf "  %d. [%s] %s\n" "$i" "$ts_val" "$inf"
          ((i++))
        done < "$FRICTION_PATH"
        echo ""
        echo "Verdict: $(_verdict_label "pass")"
      fi
      return 0
      ;;
    *)
      echo "Usage: ./harness friction <add|list>"
      echo ""
      echo "  add \"<message>\"   Append a friction record"
      echo "  list              Show recorded friction records"
      return 3
      ;;
  esac
}

# ── Main dispatch ──────────────────────────────────────────────
VERB="${1:-}"
if [[ "$VERB" == "--json" ]]; then
  JSON_MODE=true
  shift 1 2>/dev/null || true
  VERB="${1:-}"
fi
shift 1 2>/dev/null || true

case "$VERB" in
  help|--help|-h|"")
    cmd_help
    ;;
  orient)
    cmd_orient "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  install)
    cmd_install "$@"
    ;;
  lint)
    cmd_lint "$@"
    ;;
  format_check)
    cmd_format_check "$@"
    ;;
  test)
    cmd_test "$@"
    ;;
  e2e)
    cmd_e2e "$@"
    ;;
  build)
    cmd_build "$@"
    ;;
  smoke)
    cmd_smoke "$@"
    ;;
  boot)
    cmd_boot "$@"
    ;;
  verify)
    cmd_verify "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  clean)
    cmd_clean "$@"
    ;;
  friction)
    cmd_friction "$@"
    ;;
  *)
    echo ""
    echo "Unknown verb: $(_red "$VERB")"
    echo ""
    echo "Run $(_bold "./harness help") for available commands."
    exit 3
    ;;
esac

{
  "name": "devdeck",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [3000],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true,
      "installOhMyZsh": true,
      "installOhMyZshConfig": true
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker": {},
    "ghcr.io/devcontainers/features/node": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/devcontainers/features/copilot-cli": {},
    "ghcr.io/rosstaco/devcontainer-features/copilot-persistence:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/just": {},
    "ghcr.io/jsburckhardt/devcontainer-features/tmux": {},
    "ghcr.io/stuartleeks/dev-container-features/shell-history": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "chat.agent.maxRequests": 2000,
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "editor.tabSize": 2,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "files.autoSave": "onWindowChange",
        "chat.customAgentInSubagent.enabled": true,
        "typescript.preferences.importModuleSpecifier": "non-relative"
      },
      "extensions": [
        "GitHub.vscode-github-actions",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "shardulm94.trailing-spaces",
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ]
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "tmux -S .devcontainer/.tmux-shared has-session -t devdeck 2>/dev/null || tmux -S .devcontainer/.tmux-shared new -d -s devdeck",
  "remoteUser": "vscode",
  "hostRequirements": {
    "memory": "4gb"
  },
  "remoteEnv": {
    "HOST_PROJECT_PATH": "${localWorkspaceFolder}"
  },
  "mounts": [
    "source=${env:HOME}${env:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached"
  ]
}
